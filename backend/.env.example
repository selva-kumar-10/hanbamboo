# ── Server ─────────────────────────────────────
PORT=5000

# ── MongoDB ─────────────────────────────────────
# Local:  mongodb://localhost:27017/hanbamboo
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/hanbamboo
MONGO_URI=mongodb://localhost:27017/hanbamboo

# ── JWT ─────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=hanbamboo_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ── Admin Seed ──────────────────────────────────
# Used only when running: node seed.js
ADMIN_EMAIL=admin@hanbamboo.in
ADMIN_PASSWORD=Admin@123

# ── WhatsApp ─────────────────────────────────────
WHATSAPP_NUMBER=918870969828
